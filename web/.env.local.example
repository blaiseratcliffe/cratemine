# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/cratemine

# Auth.js
AUTH_SECRET=replace-with-a-random-32-char-string

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# SoundCloud OAuth
SC_CLIENT_ID=
SC_CLIENT_SECRET=
SC_REDIRECT_URI=http://localhost:3000/auth/soundcloud/callback

# PKCE session (can reuse AUTH_SECRET)
SESSION_SECRET=replace-with-a-random-32-char-string

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_UNLIMITED_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_UNLIMITED_PRICE_ID=price_...

# Resend (feedback emails)
RESEND_API_KEY=re_...
